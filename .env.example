# Runtime defaults loaded automatically by main.py and main_gpt.sh

# LLM
LLM_PROVIDER=
LLM_MODEL=
LLM_AUTH_MODE=api_key
LLM_BASE_URL=
LLM_API_KEY=
LLM_TEMPERATURE=0.5
CODEX_AUTH_FILE=~/.codex/auth.json
CODEX_BRIDGE_URL=http://127.0.0.1:8765/v1
CODEX_BRIDGE_ISSUER=https://auth.openai.com
CODEX_API_BASE=https://api.openai.com/v1
CODEX_BRIDGE_START_TIMEOUT=15

# Email
SMTP_SERVER=
SMTP_PORT=
SMTP_SENDER=
SMTP_RECEIVER=
SMTP_PASSWORD=

# Twitter / X via RapidAPI
X_RAPIDAPI_KEY=
X_RAPIDAPI_HOST=twitter-api45.p.rapidapi.com
X_ACCOUNTS_FILE=x_accounts.txt
X_DISCOVER_ACCOUNTS=0
X_MERGE_STATIC_ACCOUNTS=0
X_USE_PERSISTED_ACCOUNTS=0
X_SKIP_DISCOVERY_IF_PERSISTED=1
X_DISCOVERY_PERSIST_FILE=x_accounts.discovered.txt
X_PROFILE_FILE=
X_PROFILE_URLS=
X_DISCOVERY_ROUNDS=3
X_DISCOVERY_EXPANSION_ROUNDS=2
X_DISCOVERY_MAX_CANDIDATES=48
X_DISCOVERY_MAX_FINAL_ACCOUNTS=12
X_DISCOVERY_MAX_CORE_ACCOUNTS=12
X_DISCOVERY_MAX_EXTENDED_ACCOUNTS=24
X_DISCOVERY_SEARCH_RESULTS_PER_QUERY=6
X_DISCOVERY_SAMPLE_TWEETS=2
X_DISCOVERY_SEARCH_TIMEOUT=12
X_DISCOVERY_MIN_SCORE=6.0

# Optional script defaults
DAILY_SOURCES="github huggingface"
NUM_WORKERS=8
DESCRIPTION_FILE=description.txt
GH_LANGUAGES="all"
GH_SINCE=daily
GH_MAX_REPOS=30
HF_CONTENT_TYPES="papers models"
HF_MAX_PAPERS=30
HF_MAX_MODELS=15
